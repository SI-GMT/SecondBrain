.DS_Store
Thumbs.db

# Le vault memoire est local a chaque poste : on ne versionne que le squelette
memory/*
!memory/index.md
!memory/archives/
!memory/projects/

# Dans archives/ et projects/, on ne garde que le .gitkeep
memory/archives/*
!memory/archives/.gitkeep
memory/projects/*
!memory/projects/.gitkeep

# Config Obsidian locale au poste
memory/.obsidian/

# Fichiers temporaires Obsidian
*.tmp.*

# Settings locaux Claude Code (par poste)
.claude/settings.local.json
.claude/

# Symlinks workspace Antigravity CLI (per-poste, vers ~/.gemini/config/projects/)
.antigravitycli/

# Python build / cache
__pycache__/
*.pyc
.venv/

# uv lockfile (mcp-server is distributed as a library via pipx — lockfile
# is a consumer concern, not committed to the kit repo).
mcp-server/uv.lock

# desktop-app build artifacts — never committed, regenerated per build.
desktop-app/.venv-build/
desktop-app/dist/
desktop-app/build/generated-icons/
desktop-app/build/SecondBrainTray/
desktop-app/build/sb-desktop/
desktop-app/build/release-kit/
desktop-app/build/.cache/
desktop-app/.coverage
desktop-app/.pytest_cache/

# Generated at build time by build_windows.ps1 from pyproject.toml.
# Inside a PyInstaller bundle this file is the authoritative source for
# __version__; in a dev checkout it should not exist (importlib.metadata
# resolves the editable install version instead).
desktop-app/src/sb_desktop/_version.py
