.DS_Store
Thumbs.db

# Le vault memoire est local a chaque poste : on ne versionne que le squelette
memory/*
!memory/index.md
!memory/archives/
!memory/projects/

# Dans archives/ et projects/, on ne garde que le .gitkeep
memory/archives/*
!memory/archives/.gitkeep
memory/projects/*
!memory/projects/.gitkeep

# Config Obsidian locale au poste
memory/.obsidian/

# Fichiers temporaires Obsidian
*.tmp.*

# Settings locaux Claude Code (par poste)
.claude/settings.local.json
.claude/

# Python build / cache
__pycache__/
*.pyc
.venv/

# uv lockfile (mcp-server is distributed as a library via pipx — lockfile
# is a consumer concern, not committed to the kit repo).
mcp-server/uv.lock

# desktop-app build artifacts — never committed, regenerated per build.
desktop-app/.venv-build/
desktop-app/dist/
desktop-app/build/generated-icons/
desktop-app/build/SecondBrainTray/
desktop-app/build/sb-desktop/
desktop-app/.coverage
desktop-app/.pytest_cache/
